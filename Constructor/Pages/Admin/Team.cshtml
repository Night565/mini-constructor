@page
@model TeamModel

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Команда | Админ-панель</title>
    <link rel="stylesheet" href="~/css/admin.css">
</head>
<body class="admin-page">
    <main class="admin-shell">
        <header class="admin-topbar">
            <a class="admin-brand" asp-page="/Admin/Index">
                <span class="admin-brand__title">TravelLine.Tech</span>
                <span class="admin-brand__caption">Админ-панель</span>
            </a>
            <div class="admin-actions">
                <a class="admin-button admin-button--secondary" asp-page="/Admin/Index">Назад</a>
                <a class="admin-button admin-button--secondary" asp-page="/Index">На сайт</a>
            </div>
        </header>

        <div class="admin-container">
            <div class="admin-page__header">
                <div>
                    <h1>Команда</h1>
                </div>
            </div>

            <div class="admin-validation" data-admin-validation asp-validation-summary="All"></div>

            <div class="admin-main-grid">
                <section class="admin-card">
                    <h2>Добавить сотрудника</h2>
                    <form class="admin-form" method="post" asp-page-handler="CreateTeamMember" enctype="multipart/form-data">
                        <div class="admin-field">
                            <label>Имя</label>
                            <input asp-for="NewTeamMember.FullName">
                        </div>
                        <div class="admin-field">
                            <label>Должность</label>
                            <input asp-for="NewTeamMember.Position">
                        </div>
                        <div class="admin-field">
                            <label>Фото</label>
                            <input type="file" asp-for="NewPhotoFile">
                        </div>
                        <div class="admin-field">
                            <label>Порядок</label>
                            <input asp-for="NewTeamMember.Order" type="number">
                        </div>
                        <button class="admin-button" type="submit">Добавить</button>
                    </form>
                </section>

                <section class="admin-card">
                    <h2>Текущая команда</h2>
                    @if (Model.TeamMembers.Count == 0)
                    {
                        <p class="admin-empty">Нет добавленных сотрудников</p>
                    }
                    else
                    {
                        <ul class="admin-list">
                            @foreach (var member in Model.TeamMembers)
                            {
                                <li class="admin-list__item">
                                    <div class="admin-list__summary">
                                        @if (!string.IsNullOrWhiteSpace(member.PhotoPath))
                                        {
                                            <img class="admin-photo" src="@member.PhotoPath" alt="@member.FullName">
                                        }
                                        <div>
                                            <strong>@member.FullName</strong>
                                            <span>@member.Position</span>
                                        </div>
                                        <span class="admin-list__order">@member.Order</span>
                                    </div>

                                    <form class="admin-form" method="post" asp-page-handler="UpdateTeamMember" asp-route-id="@member.Id" enctype="multipart/form-data">
                                        <div class="admin-field">
                                            <label>Имя</label>
                                            <input name="fullName" value="@member.FullName">
                                        </div>
                                        <div class="admin-field">
                                            <label>Должность</label>
                                            <input name="position" value="@member.Position">
                                        </div>
                                        <div class="admin-field">
                                            <label>Новое фото</label>
                                            <input name="photoFile" type="file">
                                        </div>
                                        <div class="admin-field">
                                            <label>Порядок</label>
                                            <input name="order" type="number" value="@member.Order">
                                        </div>
                                        <button class="admin-button admin-button--small" type="submit">Сохранить</button>
                                    </form>

                                    <form class="admin-list__actions" method="post" asp-page-handler="DeleteTeamMember" asp-route-id="@member.Id">
                                        <button class="admin-button admin-button--danger admin-button--small" type="submit">Удалить</button>
                                    </form>
                                </li>
                            }
                        </ul>
                    }
                </section>
            </div>
        </div>
    </main>
    <script src="~/js/admin-validation.js"></script>
</body>
</html>
