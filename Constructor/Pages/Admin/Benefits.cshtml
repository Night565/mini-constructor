@page
@model BenefitsModel

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Плюшки | Админ-панель</title>
    <link rel="stylesheet" href="~/css/admin.css">
</head>
<body class="admin-page">
    <main class="admin-shell">
        <header class="admin-topbar">
            <a class="admin-brand" asp-page="/Admin/Index">
                <span class="admin-brand__title">TravelLine.Tech</span>
                <span class="admin-brand__caption">Админ-панель</span>
            </a>
            <div class="admin-actions">
                <a class="admin-button admin-button--secondary" asp-page="/Admin/Index">Назад</a>
                <a class="admin-button admin-button--secondary" asp-page="/Index">На сайт</a>
            </div>
        </header>
        <div class="admin-container">
            <div class="admin-page__header">
                <div>
                    <h1>Плюшки</h1>
                </div>
            </div>
            <div class="admin-validation" data-admin-validation asp-validation-summary="All"></div>
            <div class="admin-main-grid">
                <section class="admin-card">
                    <h2>Добавить</h2>
                    <form class="admin-form" method="post" asp-page-handler="CreateBenefit">
                        <div class="admin-field">
                            <label>Заголовок</label>
                            <input asp-for="NewBenefit.Title">
                        </div>
                        <div class="admin-field">
                            <label>Описание</label>
                            <textarea asp-for="NewBenefit.Description"></textarea>
                        </div>
                        <div class="admin-field">
                            <label>Порядок</label>
                            <input asp-for="NewBenefit.Order" type="number">
                        </div>
                        <button class="admin-button" type="submit">Добавить</button>
                    </form>
                </section>
                <section class="admin-card">
                    <h2>Текущие плюшки</h2>
                    @if (Model.Benefits.Count == 0)
                    {
                        <p class="admin-empty">Нет добавленных плюшек</p>
                    }
                    else
                    {
                        <ul class="admin-list">
                            @foreach (var benefit in Model.Benefits)
                            {
                                <li class="admin-list__item">
                                    <div class="admin-list__summary">
                                        <div>
                                            <strong>@benefit.Title</strong>
                                            <p>@benefit.Description</p>
                                        </div>
                                        <span class="admin-list__order">@benefit.Order</span>
                                    </div>

                                    <form class="admin-form" method="post" asp-page-handler="UpdateBenefit" asp-route-id="@benefit.Id">
                                        <div class="admin-field">
                                            <label>Заголовок</label>
                                            <input name="title" value="@benefit.Title">
                                        </div>
                                        <div class="admin-field">
                                            <label>Описание</label>
                                            <textarea name="description">@benefit.Description</textarea>
                                        </div>
                                        <div class="admin-field">
                                            <label>Порядок</label>
                                            <input name="order" type="number" value="@benefit.Order">
                                        </div>
                                        <button class="admin-button admin-button--small" type="submit">Сохранить</button>
                                    </form>
                                    <form class="admin-list__actions" method="post" asp-page-handler="DeleteBenefit" asp-route-id="@benefit.Id">
                                        <button class="admin-button admin-button--danger admin-button--small" type="submit">Удалить</button>
                                    </form>
                                </li>
                            }
                        </ul>
                    }
                </section>
            </div>
        </div>
    </main>
    <script src="~/js/admin-validation.js"></script>
</body>
</html>
